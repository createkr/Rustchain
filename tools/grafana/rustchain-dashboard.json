            {
              "options": {
                "0": { "color": "red", "text": "DOWN" },
                "1": { "color": "#8b5cf6", "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "#8b5cf6", "value": 1 }
